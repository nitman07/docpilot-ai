# App
APP_NAME=DocPilot
APP_VERSION=0.1.0
DEBUG=false

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=docpilot
POSTGRES_PASSWORD=docpilot
POSTGRES_DB=docpilot

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Ollama
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow_data/mlflow.db
MLFLOW_EXPERIMENT_NAME=docpilot-rag
